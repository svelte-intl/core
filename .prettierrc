{
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 100,
	"overrides": [
		{
			"files": "*.svelte",
			"options": {
				"parser": "svelte"
			}
		},
		{
			"files": [
				"*.svelte",
				"*.html"
			],
			"options": {
				"plugins": [
					"prettier-plugin-svelte",
					"prettier-plugin-tailwindcss"
				]
			}
		}
	],
	"tailwindStylesheet": "./packages/svelte-intl/src/routes/layout.css"
}