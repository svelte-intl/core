{
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 80,
	"overrides": [
		{
			"files": "*.svelte",
			"options": {
				"parser": "svelte"
			}
		},
		{
			"files": ["*.svelte", "*.html"],
			"options": {
				"plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"]
			}
		}
	],
	"tailwindStylesheet": ".//src/routes/layout.css"
}
